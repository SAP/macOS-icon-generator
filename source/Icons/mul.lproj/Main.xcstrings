    "Wek-xH-9Uy.title" : {
      "comment" : "Class = \"NSTextFieldCell\"; title = \"You can add a prefix to the icon files created by this application. Unless otherwise specified, the prefix is either the name of the application or the name of the image file you selected to create the icon set. If you want to add a prefix, please enable the option below.\"; ObjectID = \"Wek-xH-9Uy\";",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du kannst den von diesem Programm erstellten Icons ein Präfix hinzufügen. Falls nicht anderweitig angegeben, ist das Präfix entweder der Name des Programms oder der Name der Bilddatei, die Du für die Erstellung des Icon-Sets ausgewählt hast. Wenn Du ein Präfix hinzufügen möchtest, aktiviere bitte die unten stehende Option."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "You can add a prefix to the icon files created by this application. Unless otherwise specified, the prefix is either the name of the application or the name of the image file you selected to create the icon set. If you want to add a prefix, please enable the option below."
          }
        }
      }
    },
    "Wj1-si-iY6.title" : {
      "comment" : "Class = \"NSTextFieldCell\"; title = \"Max\"; ObjectID = \"Wj1-si-iY6\";",
      "extractionState" : "extracted_with_value",
