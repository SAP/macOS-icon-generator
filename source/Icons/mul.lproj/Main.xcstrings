    "dwS-Bc-ZLe.title" : {
      "comment" : "Class = \"NSTextFieldCell\"; title = \"If you frequently add overlay images to an install icon and the overlay images always have the same size and need to be displayed in the same position, Icons can remember the last size and position of the overlay image so you do not have to reposition it each time. Please enable the option below if you want Icons to remember the position.\"; ObjectID = \"dwS-Bc-ZLe\";",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Du häufig Überlagerungsbilder zu einem Installations-Icon hinzufügst und diese immer die gleiche Größe haben und in der gleichen Position angezeigt werden sollen, kann Icons die letzte Größe und Position des Überlagerungsbildes speichern, so dass Du es nicht jedes Mal neu positionieren musst. Bitte aktiviere die unten stehende Option, wenn Du möchtest, dass sich Icons die Position merkt."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "If you frequently add overlay images to an install icon and the overlay images always have the same size and need to be displayed in the same position, Icons can remember the last size and position of the overlay image so you do not have to reposition it each time. Please enable the option below if you want Icons to remember the position."
          }
        }
      }
    },
    "Dwv-bm-otT.title" : {
