    "Ee2-cC-Wmu.title" : {
      "comment" : "Class = \"NSTextFieldCell\"; title = \"This application comes with a Finder extension that allows you to create an icon set directly in the Finder by right-clicking an application or an image file. By default, the extension uses the settings made in the Icons application. So it applies the default banner, uses the selected output size and animation duration, and creates only the icon types selected in the application.\\n\\nIf you do not want this and would rather have the extension create icon sets with the default settings instead, please activate the option below.\"; ObjectID = \"Ee2-cC-Wmu\";",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieses Programm enthält eine Finder-Erweiterung, die es Dir ermöglicht, ein Icon-Set direkt im Finder zu erstellen, indem Du mit der rechten Maustaste auf ein Programm oder eine Bilddatei klickst. Standardmäßig verwendet die Erweiterung die Einstellungen, die im Programm Icons vorgenommen wurden. Sie wendet also das Standardbanner an, verwendet die ausgewählte Ausgabegröße und Animationsdauer und erstellt nur die, in der Anwendung ausgewählten, Icon-Typen.\n\nWenn Du das nicht möchtest und die Erweiterung stattdessen lieber Icon-Sets mit den Standardeinstellungen erstellen soll, aktiviere bitte die unten stehende Option."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "This application comes with a Finder extension that allows you to create an icon set directly in the Finder by right-clicking an application or an image file. By default, the extension uses the settings made in the Icons application. So it applies the default banner, uses the selected output size and animation duration, and creates only the icon types selected in the application.\n\nIf you do not want this and would rather have the extension create icon sets with the default settings instead, please activate the option below."
          }
        }
      }
    },
