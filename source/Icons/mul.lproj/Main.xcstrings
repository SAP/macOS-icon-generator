            "state" : "new",
            "value" : "Max"
          }
        }
      }
    },
    "wka-K8-1eZ.title" : {
      "comment" : "Class = \"NSTextFieldCell\"; title = \"This application adds a delete badge to the uninstall icon in the top left corner. To use your own badge instead of the default one, please select an image file using the menu below or paste an SVG symbol that you previously copied from SF Symbols.\\n\\nSF Symbols can be obtained for free directly from Apple. To download it, go to https://developer.apple.com/sf-symbols/.\"; ObjectID = \"wka-K8-1eZ\";",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dieses Programm fügt dem Deinstallations-Icon oben links ein Löschsymbol hinzu. Wenn Du anstatt des Standardsymbols Dein eigenes Symbol verwenden möchtest, dann wähle bitte eine Bilddatei über das unten stehende Menü aus, oder füge ein SVG-Symbol ein, welches Du vorher in SF Symbols kopiert hast.\n\nSF Symbols kann kostenlos direkt von Apple bezogen werden. Gehe einfach auf https://developer.apple.com/sf-symbols/, um es herunterzuladen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "This application adds a delete badge to the uninstall icon in the top left corner. To use your own badge instead of the default one, please select an image file using the menu below or paste an SVG symbol that you previously copied from SF Symbols.\n\nSF Symbols can be obtained for free directly from Apple. To download it, go to https://developer.apple.com/sf-symbols/."
          }
        }
      }
    },
