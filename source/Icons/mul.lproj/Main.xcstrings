    "Kyc-tm-u7m.title" : {
      "comment" : "Class = \"NSTextFieldCell\"; title = \"By default, this application uses the image as it is when creating an icon based on an image. To render your images in a macOS icon shape instead, please enable the option below.\"; ObjectID = \"Kyc-tm-u7m\";",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Standardmäßig verwendet dieses Programm das Bild unverändert, wenn ein Icon auf Basis eines Bildes erstellt wird. Um Deine Bilder stattdessen in der Form eines macOS Icons darzustellen, aktiviere bitte die unten stehende Option."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "By default, this application uses the image as it is when creating an icon based on an image. To render your images in a macOS icon shape instead, please enable the option below."
          }
        }
      }
