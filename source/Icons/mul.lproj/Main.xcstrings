    "Bat-gB-YKN.title" : {
      "comment" : "Class = \"NSTextFieldCell\"; title = \"When creating an icon based on an image or using the Image Playground feature, you can choose whether the banner should be drawn over or inside the icon. Please enable or disable the option below based on your needs.\"; ObjectID = \"Bat-gB-YKN\";",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Du ein Icon auf Basis eines Bildes erstellst oder die Funktion „Image Playground“ verwendest, kannst Du wählen, ob das Banner über oder innerhalb des Icons gezeichnet werden soll. Bitte aktiviere oder deaktiviere die unten stehende Option entsprechend Deinen Anforderungen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "When creating an icon based on an image or using the Image Playground feature, you can choose whether the banner should be drawn over or inside the icon. Please enable or disable the option below based on your needs."
          }
        }
      }
    },
