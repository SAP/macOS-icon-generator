    "f3z-FN-AoI.title" : {
      "comment" : "Class = \"NSTextFieldCell\"; title = \"If you create an icon based on an image or using the Image Playground feature, the icon will be shaped like those introduced in macOS 26. To use the older icon shape from before macOS 26, please enable the option below.\"; ObjectID = \"f3z-FN-AoI\";",
      "extractionState" : "extracted_with_value",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Du ein Icon auf Basis eines Bildes oder mithilfe der Funktion „Image Playground“ erstellst, bekommt das Icon die in macOS 26 eingeführte Form. Um die ältere Form aus der Zeit vor macOS 26 zu verwenden, aktiviere bitte die unten stehende Option."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "If you create an icon based on an image or using the Image Playground feature, the icon will be shaped like those introduced in macOS 26. To use the older icon shape from before macOS 26, please enable the option below."
          }
        }
      }
    },
