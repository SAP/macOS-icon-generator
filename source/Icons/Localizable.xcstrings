      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Beim Speichern der Icons ist ein Fehler aufgetreten. Bitte stelle sicher, dass Du Schreibrechte für den gewählten Speicherort hast und versuche es erneut."
