    "bannerExistsDialogMessage" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ein Banner mit demselben Text und denselben Farben befindet sich bereits in der Liste der gespeicherten Banner. Möchtest Du wirklich das exakt selbe Banner noch einmal speichern?"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "A banner with the same text and colors is already in the list of saved banners. Do you really want to save the exact same banner again?"
          }
        }
      }
    },
    "bannerExistsDialogTitle" : {
      "localizations" : {
        "de" : {
