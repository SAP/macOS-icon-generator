    "badgeIconMarginSliderTooltip" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwende diesen Schieberegler, um den Abstand des Löschsymbols von der Ecke anzupassen. Aktuell beträgt der Abstand %@ der Größe des Icons."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Use this slider to adjust the margin between the badge icon and the corner. The margin is currently %@ of the icon size."
          }
        }
      }
    },
    "badgeIconSizeSliderTooltip" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
