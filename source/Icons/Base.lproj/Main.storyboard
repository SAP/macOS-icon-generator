                                <textFieldCell key="cell" controlSize="small" allowsUndo="NO" id="dwS-Bc-ZLe">
                                    <font key="font" metaFont="smallSystem"/>
                                    <string key="title">If you frequently add overlay images to an install icon and the overlay images always have the same size and need to be displayed in the same position, Icons can remember the last size and position of the overlay image so you do not have to reposition it each time. Please enable the option below if you want Icons to remember the position.</string>
                                    <color key="textColor" name="labelColor" catalog="System" colorSpace="catalog"/>
                                    <color key="backgroundColor" name="textBackgroundColor" catalog="System" colorSpace="catalog"/>
